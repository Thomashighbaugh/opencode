{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/glm-5.1:cloud",
  "provider": {
    "ollama": {
      "models": {
        "glm-5.1:cloud": {
          "_launch": true,
          "name": "glm-5.1:cloud"
        },
        "glm-5:cloud": {
          "_launch": true,
          "limit": {
            "context": 202752,
            "output": 131072
          },
          "name": "glm-5:cloud"
        },
        "kimi-k2.5:cloud": {
          "_launch": true,
          "limit": {
            "context": 262144,
            "output": 262144
          },
          "name": "kimi-k2.5:cloud"
        },
        "minimax-m2.7:cloud": {
          "_launch": true,
          "limit": {
            "context": 204800,
            "output": 128000
          },
          "name": "minimax-m2.7:cloud"
        },
        "qwen3.5:cloud": {
          "_launch": true,
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "name": "qwen3.5:cloud"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  },
  "plugin": [
    "opencode-bytheway@0.3.10"
  ],
 
 
 
 
 
 
 
}
