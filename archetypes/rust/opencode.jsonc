{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "./rules/rust-conventions.md",
    "./rules/testing-conventions.md"
  ],
  "resource_tags": {
    "include": ["rust"],
    "exclude": ["typescript", "react", "nextjs", "python", "go"]
  },
  "permission": {
    "edit": "allow",
    "bash": { "git *": "allow", "cargo *": "allow", "rustup *": "allow", "nix *": "allow", "*": "ask" }
  }
}
