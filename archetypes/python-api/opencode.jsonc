{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "./rules/python-conventions.md",
    "./rules/testing-conventions.md"
  ],
  "resource_tags": {
    "include": ["python", "pytest", "api"],
    "exclude": ["typescript", "react", "nextjs", "rust"]
  },
  "permission": {
    "edit": "allow",
    "bash": { "git *": "allow", "uv *": "allow", "pip *": "allow", "poetry *": "allow", "nix *": "allow", "*": "ask" }
  }
}
