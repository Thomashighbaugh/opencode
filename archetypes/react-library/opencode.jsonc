{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "./rules/library-conventions.md",
    "./rules/testing-conventions.md"
  ],
  "resource_tags": {
    "include": ["typescript", "react", "frontend", "storybook"],
    "exclude": ["python", "rust", "python-api"]
  },
  "permission": {
    "edit": "allow",
    "bash": { "git *": "allow", "npm *": "allow", "pnpm *": "allow", "nix *": "allow", "*": "ask" }
  }
}
